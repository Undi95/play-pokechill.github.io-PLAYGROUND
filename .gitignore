# ─── Standard ignores ───
node_modules/
*.pyc
__pycache__/

# ─── Local-only: translator workstation artifacts ───
# Claude Code's persistent memory store (task context across sessions)
memory/
# Reference save used by probes to bypass the tutorial
save.json
# Screenshots folder (manual / probe output)
screenshots/
# Legacy compiled single-file overlay from before the engine/fr split
scripts/fr/

# ─── Translation audit tooling (keep locally, re-run on demand) ───
# Python scanners that crawl game .js files for untranslated / cross-wired
# user-facing strings. See scripts/i18n/README.md for their purpose.
_audit_bugs.py
_audit_bugs2.py
_audit_crosswire.py
_find_en.py
_i18n_plan.md

# Playwright probes (need a local `python -m http.server 8765` + save.json)
# that drive the game and flag any remaining English strings at runtime.
_probe_fr.js
_probe_deep.js
_probe_force.js
_extract_coverage.js

# Probe output (screenshots + findings_*.json per panel visited)
_probe_out/
_probe_deep_out/
_probe_force_out/

# Audit / scanner JSON output (regenerated by running the scripts above)
_audit_bugs.json
_audit_bugs2.json
_audit_missing.json
_untranslated.json
_remaining_english.txt
_merged_source.js
_translation_audit.md

# ─── Legacy one-shot scripts kept ignored in case they come back ───
_audit_strings.py
_audit_dynamic.py
_explore_i18n.py
I18N_STATUS.md
check_all_missing.py
check_missing.py
fix_encoding.py
find_missing.py
dedupe_fr_js.py
patch_and_scan.py
test_regex.py
package.json
package-lock.json
